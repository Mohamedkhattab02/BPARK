<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0"
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 20; 
           -fx-border-radius: 20;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.ParkingTimeReportController">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Chart Icon Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="📊" style="-fx-font-size: 28px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Parking Time Report" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="Overview of Parking Count, Extensions and Delays for Subscribers" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" style="-fx-padding: 40;">
            <!-- Chart Card -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 35; 
                         -fx-spacing: 25; 
                         -fx-border-color: #e2e8f0; 
                         -fx-border-width: 1px; 
                         -fx-border-radius: 15; 
                         -fx-max-width: 900;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <!-- Card Header -->
                <HBox alignment="CENTER" spacing="10">
                    <Label text="⏱️" style="-fx-font-size: 24px;" />
                    <Label text="Parking Statistics Analysis" 
                           style="-fx-font-size: 22px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="22.0" />
                        </font>
                    </Label>
                </HBox>
                
                <Separator style="-fx-background-color: #e2e8f0;" />
                
                <!-- Metrics Boxes - צבעים מותאמים -->
                <HBox alignment="CENTER" spacing="25">
                    <!-- Parking Count - כחול -->
                    <VBox alignment="CENTER" 
                          style="-fx-background-color: linear-gradient(to bottom, #dbeafe, #bfdbfe);
                                 -fx-padding: 20;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #3b82f6;
                                 -fx-border-width: 2px;
                                 -fx-border-radius: 12;
                                 -fx-min-width: 180;">
                        <effect>
                            <DropShadow color="#3b82f640" radius="10.0" spread="0.1" />
                        </effect>
                        <Label text="🚗" style="-fx-font-size: 22px;" />
                        <Label text="Parking Count" 
                               style="-fx-font-size: 17px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #1e40af;" />
                        <Label text="Total sessions" 
                               style="-fx-font-size: 12px; 
                                      -fx-text-fill: #3b82f6;" />
                    </VBox>
                    
                    <!-- Extensions - ירוק -->
                    <VBox alignment="CENTER" 
                          style="-fx-background-color: linear-gradient(to bottom, #dcfce7, #bbf7d0);
                                 -fx-padding: 20;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #22c55e;
                                 -fx-border-width: 2px;
                                 -fx-border-radius: 12;
                                 -fx-min-width: 180;">
                        <effect>
                            <DropShadow color="#22c55e40" radius="10.0" spread="0.1" />
                        </effect>
                        <Label text="⏰" style="-fx-font-size: 22px;" />
                        <Label text="Extensions" 
                               style="-fx-font-size: 17px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #15803d;" />
                        <Label text="Time extensions" 
                               style="-fx-font-size: 12px; 
                                      -fx-text-fill: #16a34a;" />
                    </VBox>
                    
                    <!-- Delays - אדום -->
                    <VBox alignment="CENTER" 
                          style="-fx-background-color: linear-gradient(to bottom, #fee2e2, #fecaca);
                                 -fx-padding: 20;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #ef4444;
                                 -fx-border-width: 2px;
                                 -fx-border-radius: 12;
                                 -fx-min-width: 180;">
                        <effect>
                            <DropShadow color="#ef444440" radius="10.0" spread="0.1" />
                        </effect>
                        <Label text="⚠️" style="-fx-font-size: 22px;" />
                        <Label text="Delays" 
                               style="-fx-font-size: 17px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #dc2626;" />
                        <Label text="Overstay incidents" 
                               style="-fx-font-size: 12px; 
                                      -fx-text-fill: #ef4444;" />
                    </VBox>
                </HBox>
                
                <!-- Chart Container -->
                <VBox style="-fx-background-color: #f8fafc; 
                             -fx-padding: 20; 
                             -fx-background-radius: 10; 
                             -fx-border-color: #e2e8f0; 
                             -fx-border-width: 1px; 
                             -fx-border-radius: 10;">
                    <BarChart fx:id="parkingChart" 
                              prefHeight="400.0" 
                              prefWidth="800.0" 
                              style="-fx-background-color: transparent; 
                                     -fx-alternative-row-fill-visible: false;
                                     -fx-legend-side: RIGHT;
                                     CHART_COLOR_1: #3b82f6;
                                     CHART_COLOR_2: #22c55e; 
                                     CHART_COLOR_3: #ef4444;">
                        <xAxis>
                            <CategoryAxis label="Subscriber" 
                                         fx:id="xAxis" 
                                         style="-fx-tick-label-fill: #374151; 
                                                -fx-font-weight: bold;" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="yAxis" 
                                       label="Count" 
                                       style="-fx-tick-label-fill: #374151; 
                                              -fx-font-weight: bold;" />
                        </yAxis>
                    </BarChart>
                </VBox>
            </VBox>
        </VBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <Button text="← Back" 
                    onAction="#handleBack" 
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 15px; 
                           -fx-padding: 12 35; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c; 
                           -fx-border-width: 1px; 
                           -fx-border-radius: 25; 
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>

</BorderPane>