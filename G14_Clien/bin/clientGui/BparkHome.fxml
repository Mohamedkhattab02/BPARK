<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
                   -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
                   -fx-border-width: 2px; 
                   -fx-background-radius: 15; 
                   -fx-border-radius: 15;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGui.BparkHomeController">

    <effect>
        <DropShadow color="#00000080" radius="20.0" spread="0.1" offsetY="10" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 15 15 0 0; 
                     -fx-padding: 15;">
            <effect>
                <InnerShadow color="#ffffff20" radius="8.0" />
            </effect>
            
            <!-- Logo and Title -->
            <HBox alignment="CENTER" spacing="15">
                <StackPane>
                    <Circle radius="30" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="28" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="🚗" style="-fx-font-size: 24px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <VBox alignment="CENTER">
                    <Label text="BPARK Parking System" 
                           style="-fx-font-size: 32px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="32.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="Your Smart Parking Solution" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 25;">
            
            <!-- Login Options Cards -->
            <HBox alignment="CENTER" spacing="25">
             <!-- Subscriber Card -->
                <VBox alignment="CENTER" spacing="15"
                      style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 12; 
                             -fx-padding: 25; 
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 12;
                             -fx-pref-width: 220;
                             -fx-pref-height: 200;">
                    <effect>
                        <DropShadow color="#00000020" radius="12.0" spread="0.05" />
                    </effect>
                    
                    <Label text="👤" style="-fx-font-size: 42px;" />
                    <Label text="Subscriber" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                    <Label text="Access your account" 
                           style="-fx-font-size: 12px; 
                                  -fx-text-fill: #6b7280;
                                  -fx-text-alignment: CENTER;" 
                           wrapText="true" />
                    <Button onAction="#subscriberBtnClicked"
                            text="Login"
                            style="-fx-background-color: linear-gradient(to bottom, #3b82f6, #2563eb); 
                                   -fx-text-fill: white; 
                                   -fx-font-weight: bold; 
                                   -fx-font-size: 14px; 
                                   -fx-padding: 10 25; 
                                   -fx-background-radius: 20; 
                                   -fx-border-color: #1d4ed8;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 20;
                                   -fx-cursor: hand;">
                        <effect>
                            <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                        </effect>
                    </Button>
                </VBox>

                <!-- Attendant Card -->
                <VBox alignment="CENTER" spacing="15"
                      style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 12; 
                             -fx-padding: 25; 
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 12;
                             -fx-pref-width: 220;
                             -fx-pref-height: 200;">
                    <effect>
                        <DropShadow color="#00000020" radius="12.0" spread="0.05" />
                    </effect>
                    
                    <Label text="👷" style="-fx-font-size: 42px;" />
                    <Label text="Attendant" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                    <Label text="Manage operations" 
                           style="-fx-font-size: 12px; 
                                  -fx-text-fill: #6b7280;
                                  -fx-text-alignment: CENTER;" 
                           wrapText="true" />
                    <Button onAction="#attendantBtnClicked"
                            text="Login"
                            style="-fx-background-color: linear-gradient(to bottom, #8b5cf6, #7c3aed); 
                                   -fx-text-fill: white; 
                                   -fx-font-weight: bold; 
                                   -fx-font-size: 14px; 
                                   -fx-padding: 10 25; 
                                   -fx-background-radius: 20; 
                                   -fx-border-color: #6d28d9;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 20;
                                   -fx-cursor: hand;">
                        <effect>
                            <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                        </effect>
                    </Button>
                </VBox>

                <!-- Manager Card -->
                <VBox alignment="CENTER" spacing="15"
                      style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 12; 
                             -fx-padding: 25; 
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 12;
                             -fx-pref-width: 220;
                             -fx-pref-height: 200;">
                    <effect>
                        <DropShadow color="#00000020" radius="12.0" spread="0.05" />
                    </effect>
                    
                    <Label text="💼" style="-fx-font-size: 42px;" />
                    <Label text="Manager" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                    <Label text="System admin" 
                           style="-fx-font-size: 12px; 
                                  -fx-text-fill: #6b7280;
                                  -fx-text-alignment: CENTER;" 
                           wrapText="true" />
                    <Button onAction="#managerBtnClicked"
                            text="Login"
                            style="-fx-background-color: linear-gradient(to bottom, #f59e0b, #d97706); 
                                   -fx-text-fill: white; 
                                   -fx-font-weight: bold; 
                                   -fx-font-size: 14px; 
                                   -fx-padding: 10 25; 
                                   -fx-background-radius: 20; 
                                   -fx-border-color: #b45309;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 20;
                                   -fx-cursor: hand;">
                        <effect>
                            <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                        </effect>
                    </Button>
                </VBox>
            </HBox>

            <!-- Check Available Spots Section -->
            <VBox alignment="CENTER" spacing="15"
                  style="-fx-background-color: linear-gradient(to bottom, #dcfce7, #bbf7d0);
                         -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-border-color: #22c55e;
                         -fx-border-width: 1px;
                         -fx-border-radius: 12;
                         -fx-max-width: 500;">
                <effect>
                    <DropShadow color="#00000015" radius="8.0" spread="0.05" />
                </effect>
                
                <HBox alignment="CENTER" spacing="10">
                    <Label text="🅿️" style="-fx-font-size: 24px;" />
                    <Label text="Parking Availability" 
                           style="-fx-font-size: 16px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #15803d;">
                        <font>
                            <Font name="Segoe UI Bold" size="16.0" />
                        </font>
                    </Label>
                </HBox>
                
                <Button onAction="#handleCheckAvailableSpots"
                        text="🔍 Check Available Spots"
                        style="-fx-background-color: linear-gradient(to bottom, #22c55e, #16a34a); 
                               -fx-text-fill: white; 
                               -fx-font-weight: bold; 
                               -fx-font-size: 14px; 
                               -fx-padding: 10 25; 
                               -fx-background-radius: 20; 
                               -fx-border-color: #15803d;
                               -fx-border-width: 1px;
                               -fx-border-radius: 20;
                               -fx-cursor: hand;">
                    <effect>
                        <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                    </effect>
                </Button>
                
                <Label fx:id="lblAvailableSpots" 
                       style="-fx-font-size: 14px; 
                              -fx-font-weight: bold; 
                              -fx-text-fill: #15803d;
                              -fx-padding: 8 15;
                              -fx-background-color: #ffffff88;
                              -fx-background-radius: 8;"
                       visible="false" />
            </VBox>
            
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="15" 
              style="-fx-padding: 15; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 15 15;">
            
            <Button text="🚪 Exit" 
                    onAction="#handleExit"
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 8 25; 
                           -fx-background-radius: 20; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 20;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>

</BorderPane>