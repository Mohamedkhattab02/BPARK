<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700" prefWidth="1200" 
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 20; 
           -fx-border-radius: 20;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.ManagerHomePageController">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Profile Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Profile Avatar Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #9B59B6, #8E44AD);" />
                    <Label text="👨‍💼" style="-fx-font-size: 32px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Manager Dashboard" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="Comprehensive Management Control" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Main Content - Action Buttons -->
    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-padding: 50;">
            
            <!-- View Subscribers Button -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-pref-width: 400;
                         -fx-max-width: 400;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <Button onAction="#handleViewSubscribers" 
                        prefHeight="80.0" prefWidth="350.0" 
                        style="-fx-background-color: linear-gradient(to bottom, #3498DB, #2980B9); 
                               -fx-text-fill: white; 
                               -fx-font-size: 18px; 
                               -fx-font-weight: bold; 
                               -fx-background-radius: 12; 
                               -fx-cursor: hand;
                               -fx-border-color: #2471A3;
                               -fx-border-width: 1px;
                               -fx-border-radius: 12;">
                    <effect>
                        <DropShadow color="#00000040" radius="10.0" spread="0.1" />
                    </effect>
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label text="👥" style="-fx-font-size: 20px;" />
                            <Label text="View Subscribers" 
                                   style="-fx-text-fill: white; 
                                          -fx-font-size: 18px; 
                                          -fx-font-weight: bold;" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <!-- View Parking Button -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-pref-width: 400;
                         -fx-max-width: 400;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <Button onAction="#handleViewParking" 
                        prefHeight="80.0" prefWidth="350.0" 
                        style="-fx-background-color: linear-gradient(to bottom, #27AE60, #229954); 
                               -fx-text-fill: white; 
                               -fx-font-size: 18px; 
                               -fx-font-weight: bold; 
                               -fx-background-radius: 12; 
                               -fx-cursor: hand;
                               -fx-border-color: #1E8449;
                               -fx-border-width: 1px;
                               -fx-border-radius: 12;">
                    <effect>
                        <DropShadow color="#00000040" radius="10.0" spread="0.1" />
                    </effect>
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label text="🚗" style="-fx-font-size: 20px;" />
                            <Label text="View Parking" 
                                   style="-fx-text-fill: white; 
                                          -fx-font-size: 18px; 
                                          -fx-font-weight: bold;" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>

            <!-- View Reports Button -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-pref-width: 400;
                         -fx-max-width: 400;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <Button onAction="#handleViewReports" 
                        prefHeight="80.0" prefWidth="350.0" 
                        style="-fx-background-color: linear-gradient(to bottom, #9B59B6, #8E44AD); 
                               -fx-text-fill: white; 
                               -fx-font-size: 18px; 
                               -fx-font-weight: bold; 
                               -fx-background-radius: 12; 
                               -fx-cursor: hand;
                               -fx-border-color: #7D3C98;
                               -fx-border-width: 1px;
                               -fx-border-radius: 12;">
                    <effect>
                        <DropShadow color="#00000040" radius="10.0" spread="0.1" />
                    </effect>
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label text="📊" style="-fx-font-size: 20px;" />
                            <Label text="View Reports" 
                                   style="-fx-text-fill: white; 
                                          -fx-font-size: 18px; 
                                          -fx-font-weight: bold;" />
                        </HBox>
                    </graphic>
                </Button>
            </VBox>
        </VBox>
    </center>

    <!-- Footer with Exit Button -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <!-- Exit Button -->
            <Button fx:id="btnExit" onAction="#getExitBtn" 
                    text="" 
                    style="-fx-background-color: linear-gradient(to bottom, #C0392B, #A93226); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 12 30; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #922B21;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
                <graphic>
                    <HBox alignment="CENTER" spacing="8">
                        <Label text="🚪" style="-fx-font-size: 14px;" />
                        <Label text="Exit" 
                               style="-fx-text-fill: white; 
                                      -fx-font-size: 14px; 
                                      -fx-font-weight: bold;" />
                    </HBox>
                </graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>