<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700" prefWidth="1200" 
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 20; 
           -fx-border-radius: 20;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.ClientProfileController">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Profile Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Profile Avatar Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="👤" style="-fx-font-size: 32px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="User Profile" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="Personal Information Settings" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Main Content - Side by Side Layout -->
    <center>
        <HBox style="-fx-padding: 30; -fx-spacing: 30;" alignment="TOP_CENTER">
            
            <!-- Left Card - Personal Information -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-pref-width: 500;
                         -fx-max-width: 500;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <!-- Card Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📋" style="-fx-font-size: 20px;" />
                    <Label text="Personal Information" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                </HBox>
                
                <!-- Personal Info Grid -->
                <GridPane hgap="20" vgap="20" style="-fx-padding: 10 0;">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="140" />
                        <ColumnConstraints halignment="LEFT" minWidth="200" prefWidth="280" />
                    </columnConstraints>

                    <!-- Username -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="👤" style="-fx-font-size: 16px;" />
                        <Label text="Username:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblUsername" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #cbd5e1;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- Password -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="🔒" style="-fx-font-size: 16px;" />
                        <Label text="Password:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblPassword" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #cbd5e1;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- Email -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="📧" style="-fx-font-size: 16px;" />
                        <Label text="Email:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblEmail" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #cbd5e1;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Phone -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="📱" style="-fx-font-size: 16px;" />
                        <Label text="Phone Number:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblPhone" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #cbd5e1;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="3" />
                </GridPane>
            </VBox>

            <!-- Right Card - Account Details -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-pref-width: 500;
                         -fx-max-width: 500;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <!-- Card Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="⚙" style="-fx-font-size: 20px;" />
                    <Label text="Account Details" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                </HBox>
                
                <!-- Account Details Grid -->
                <GridPane hgap="20" vgap="20" style="-fx-padding: 10 0;">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120" prefWidth="160" />
                        <ColumnConstraints halignment="LEFT" minWidth="200" prefWidth="260" />
                    </columnConstraints>

                    <!-- Subscription Code -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="🎫" style="-fx-font-size: 16px;" />
                        <Label text="Subscription:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblSubscriptionCode" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #fef3c7, #fde68a); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #f59e0b;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                    <!-- Quick Access Code -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <Label text="⚡" style="-fx-font-size: 16px;" />
                        <Label text="Quick Access:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblQuickAccessCode" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #dbeafe, #bfdbfe); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #3b82f6;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <!-- Registration Date -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="📅" style="-fx-font-size: 16px;" />
                        <Label text="Registration:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblRegistrationDate" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #cbd5e1;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />

                    <!-- Delay Count -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                        <Label text="⏱" style="-fx-font-size: 16px;" />
                        <Label text="Delay Count:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblDelayCount" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #fef2f2, #fecaca); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #ef4444;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="3" />

                    <!-- Status -->
                    <HBox alignment="CENTER_RIGHT" spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="4">
                        <Label text="✅" style="-fx-font-size: 16px;" />
                        <Label text="Status:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                    </HBox>
                    <Label fx:id="lblStatus" 
                           style="-fx-text-fill: #1f2937; 
                                  -fx-font-size: 14px; 
                                  -fx-padding: 10 14; 
                                  -fx-background-color: linear-gradient(to bottom, #dcfce7, #bbf7d0); 
                                  -fx-background-radius: 8; 
                                  -fx-border-color: #22c55e;
                                  -fx-border-width: 1px;
                                  -fx-border-radius: 8;
                                  -fx-min-width: 200;" 
                           GridPane.columnIndex="1" GridPane.rowIndex="4" />
                </GridPane>
            </VBox>
        </HBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            
            <!-- Back Button -->
            <Button onAction="#handleBack" 
                    text="← Back" 
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 12 30; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>
</BorderPane>