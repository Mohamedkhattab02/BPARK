<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGui.ClientReservationHistoryController"
            prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
                   -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
                   -fx-border-width: 2px; 
                   -fx-background-radius: 20; 
                   -fx-border-radius: 20;">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- History Icon Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="📜" style="-fx-font-size: 28px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Reservation History" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="View all your past and upcoming reservations" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Table Section -->
    <center>
        <VBox spacing="25.0" alignment="TOP_CENTER" style="-fx-padding: 30;">
            <children>
                <!-- Main Card Container -->
                <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 15; 
                             -fx-padding: 25; 
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 15;">
                    <effect>
                        <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                    </effect>
                    
                    <TableView fx:id="reservationTable" prefWidth="1100.0" prefHeight="500.0"
                               style="-fx-background-color: #f8fafc;
                                      -fx-background-radius: 10;
                                      -fx-border-color: #e2e8f0; 
                                      -fx-border-width: 1px; 
                                      -fx-border-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="80.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colSpace" text="🅿️ Space" prefWidth="120.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colStart" text="📅 Start Time" prefWidth="180.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colEnd" text="🏁 End Time" prefWidth="180.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colCode" text="🔑 Confirmation" prefWidth="150.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colStatus" text="✅ Status" prefWidth="120.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                            <TableColumn fx:id="colCreatedAt" text="📆 Created" prefWidth="170.0" 
                                style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2);
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold; 
                                       -fx-alignment: CENTER;
                                       -fx-font-size: 14px;"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <effect>
                            <InnerShadow color="#00000010" radius="5.0" />
                        </effect>
                    </TableView>
                </VBox>
            </children>
        </VBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <Button fx:id="btnBack" text="← Back" onAction="#goBack"
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 15px; 
                           -fx-padding: 12 35; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>

</BorderPane>