<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clientGui.ViewParkingController"
            prefHeight="750.0" prefWidth="1200.0"
            style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
                   -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
                   -fx-border-width: 2px; 
                   -fx-background-radius: 20; 
                   -fx-border-radius: 20;">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Parking Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Parking Icon Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="🅿️" style="-fx-font-size: 32px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Parking Records" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="View and Search Parking Information" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="25.0" alignment="TOP_CENTER" style="-fx-padding: 30;">
            <children>

                <!-- Search Section Card -->
                <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 15; 
                             -fx-padding: 20; 
                             -fx-spacing: 15;
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 15;">
                    <effect>
                        <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                    </effect>
                    
                    <!-- Search Header -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔍" style="-fx-font-size: 18px;" />
                        <Label text="Search Parking Records" 
                               style="-fx-font-size: 18px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #1e40af;">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                    </HBox>
                    
                    <!-- Search Controls -->
                    <HBox spacing="20.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0;">
                        <Label text="Search by Subscriber:" 
                               style="-fx-text-fill: #374151; 
                                      -fx-font-weight: bold; 
                                      -fx-font-size: 14px;" />
                        <TextField fx:id="searchSubscriberField" 
                                   promptText="Enter Subscriber ID"
                                   style="-fx-background-color: linear-gradient(to bottom, #f1f5f9, #e2e8f0); 
                                          -fx-border-color: #cbd5e1;
                                          -fx-border-width: 1px;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 10 12;
                                          -fx-font-size: 14px;
                                          -fx-pref-width: 200;" />
                        <Button text="🔍 Search" onAction="#handleSearchBySubscriber"
                                style="-fx-background-color: linear-gradient(to bottom, #3b82f6, #2563eb); 
                                       -fx-text-fill: white; 
                                       -fx-font-weight: bold;
                                       -fx-font-size: 14px;
                                       -fx-padding: 10 20;
                                       -fx-background-radius: 8;
                                       -fx-border-color: #1d4ed8;
                                       -fx-border-width: 1px;
                                       -fx-border-radius: 8;
                                       -fx-cursor: hand;">
                            <effect>
                                <DropShadow color="#00000030" radius="5.0" />
                            </effect>
                        </Button>
                        <Button text="📋 Show All" onAction="#resetSearch"
                                style="-fx-background-color: linear-gradient(to bottom, #22c55e, #16a34a); 
                                       -fx-text-fill: white; 
                                       -fx-font-weight: bold;
                                       -fx-font-size: 14px;
                                       -fx-padding: 10 20;
                                       -fx-background-radius: 8;
                                       -fx-border-color: #15803d;
                                       -fx-border-width: 1px;
                                       -fx-border-radius: 8;
                                       -fx-cursor: hand;">
                            <effect>
                                <DropShadow color="#00000030" radius="5.0" />
                            </effect>
                        </Button>
                    </HBox>
                </VBox>

                <!-- Table Card -->
                <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                             -fx-background-radius: 15; 
                             -fx-padding: 20; 
                             -fx-spacing: 15;
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 15;">
                    <effect>
                        <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                    </effect>
                    
                    <!-- Table Header -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📊" style="-fx-font-size: 18px;" />
                        <Label text="Parking Records Table" 
                               style="-fx-font-size: 18px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #1e40af;">
                            <font>
                                <Font name="Segoe UI Bold" size="18.0" />
                            </font>
                        </Label>
                    </HBox>

                    <!-- Table -->
                    <TableView fx:id="parkingTable" prefWidth="1150.0" prefHeight="450.0"
                               style="-fx-background-color: #ffffff;
                                      -fx-border-color: #e2e8f0;
                                      -fx-border-width: 1px;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-selection-bar: #3b82f6;
                                      -fx-selection-bar-text: white;
                                      -fx-table-cell-border-color: #e2e8f0;
                                      -fx-text-fill: #1f2937;
                                      -fx-control-inner-background: #ffffff;">
                        <columns>
                            <TableColumn fx:id="colCode" text="Parking Code" prefWidth="100.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="colSpace" text="Parking Space" prefWidth="110.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="colStart" text="Start Time" prefWidth="170.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                            <TableColumn fx:id="colEnd" text="End Time" prefWidth="170.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
                            <TableColumn fx:id="colConfirm" text="Confirmation Code" prefWidth="130.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="colSubscriber" text="Subscriber" prefWidth="100.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="colExtensions" text="Extensions" prefWidth="80.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                            <TableColumn fx:id="colMaxTime" text="Max Time (min)" prefWidth="120.0"
                                         style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-alignment: CENTER;" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <effect>
                            <DropShadow color="#0000001a" radius="8.0" spread="0.02" />
                        </effect>
                    </TableView>
                </VBox>
            </children>
        </VBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <!-- Exit Button -->
            <Button text="✖ Exit" onAction="#exitWindow"
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 12 30; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>

</BorderPane>