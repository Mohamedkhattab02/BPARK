<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="700" prefWidth="1200" 
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 20; 
           -fx-border-radius: 20;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.ViewSubscribeController">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Title Section -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Subscribers Icon -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #3b82f6, #1e40af);" />
                    <Label text="👥" style="-fx-font-size: 32px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Subscribers Management" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="View and Search Subscriber Information" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Search Section -->
            <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                <Separator style="-fx-background-color: #ffffff40;" />
                
                <!-- Search Controls -->
                <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10 0;">
                    <!-- Search Icon and Label -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🔍" style="-fx-font-size: 18px;" />
                        <Label text="Search by Subscriber ID:" 
                               style="-fx-text-fill: white; 
                                      -fx-font-size: 14px; 
                                      -fx-font-weight: bold;">
                            <effect>
                                <DropShadow color="#00000040" radius="2.0" />
                            </effect>
                        </Label>
                    </HBox>
                    
                    <!-- Search Input -->
                    <TextField fx:id="searchIdField" 
                               promptText="Enter Subscriber ID..."
                               style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc);
                                      -fx-background-radius: 12;
                                      -fx-border-color: #cbd5e1;
                                      -fx-border-width: 1px;
                                      -fx-border-radius: 12;
                                      -fx-padding: 12 16;
                                      -fx-font-size: 14px;
                                      -fx-text-fill: #1f2937;
                                      -fx-min-width: 250;
                                      -fx-max-width: 250;"
                               prefWidth="250">
                        <effect>
                            <DropShadow color="#00000020" radius="5.0" />
                        </effect>
                    </TextField>
                    
                    <!-- Search Button -->
                    <Button text="🔍 Search" 
                            onAction="#handleSearchById"
                            style="-fx-background-color: linear-gradient(to bottom, #10b981, #059669); 
                                   -fx-text-fill: white; 
                                   -fx-font-weight: bold; 
                                   -fx-font-size: 14px; 
                                   -fx-padding: 12 20; 
                                   -fx-background-radius: 12; 
                                   -fx-border-color: #047857;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 12;
                                   -fx-cursor: hand;
                                   -fx-min-width: 100;">
                        <effect>
                            <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                        </effect>
                    </Button>
                    
                    <!-- Show All Button -->
                    <Button text="📋 Show All" 
                            onAction="#resetSearch"
                            style="-fx-background-color: linear-gradient(to bottom, #3b82f6, #2563eb); 
                                   -fx-text-fill: white; 
                                   -fx-font-weight: bold; 
                                   -fx-font-size: 14px; 
                                   -fx-padding: 12 20; 
                                   -fx-background-radius: 12; 
                                   -fx-border-color: #1d4ed8;
                                   -fx-border-width: 1px;
                                   -fx-border-radius: 12;
                                   -fx-cursor: hand;
                                   -fx-min-width: 110;">
                        <effect>
                            <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                        </effect>
                    </Button>
                </HBox>
            </VBox>
        </VBox>
    </top>

    <!-- Main Content - Table Section -->
    <center>
        <VBox style="-fx-padding: 30; -fx-spacing: 20;" alignment="TOP_CENTER">
            
            <!-- Table Container -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 25; 
                         -fx-spacing: 15;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <!-- Table Header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📊" style="-fx-font-size: 20px;" />
                    <Label text="Subscribers Data Table" 
                           style="-fx-font-size: 20px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="20.0" />
                        </font>
                    </Label>
                </HBox>
                
                <!-- Subscribers Table -->
                <TableView fx:id="subscriberTable" 
                          prefWidth="1100.0" 
                          prefHeight="420.0"
                          style="-fx-background-color: #ffffff;
                                 -fx-border-color: #e2e8f0;
                                 -fx-border-width: 1px;
                                 -fx-border-radius: 10;
                                 -fx-background-radius: 10;
                                 -fx-selection-bar: linear-gradient(to bottom, #dbeafe, #bfdbfe);
                                 -fx-selection-bar-text: #1e40af;
                                 -fx-table-cell-border-color: #f1f5f9;
                                 -fx-text-fill: #374151;
                                 -fx-control-inner-background: #ffffff;">
                    <columns>
                        <TableColumn fx:id="colId" text="🆔 ID" prefWidth="60.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-alignment: CENTER; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colUsername" text="👤 Username" prefWidth="120.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colFirstName" text="📝 First Name" prefWidth="120.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colLastName" text="📝 Last Name" prefWidth="120.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colEmail" text="📧 Email" prefWidth="180.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colPhone" text="📱 Phone" prefWidth="130.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colSubscriptionCode" text="🎫 Subscription" prefWidth="140.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colQuickCode" text="⚡ Quick Code" prefWidth="130.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colRegDate" text="📅 Registration" prefWidth="140.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colDelays" text="⏱ Delays" prefWidth="80.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-alignment: CENTER; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                        <TableColumn fx:id="colStatus" text="✅ Status" prefWidth="100.0"
                                     style="-fx-font-weight: bold; 
                                            -fx-text-fill: #1f2937;
                                            -fx-background-color: #f8fafc;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <effect>
                        <DropShadow color="#00000015" radius="8.0" spread="0.02" />
                    </effect>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <!-- Exit Button -->
            <Button onAction="#exitWindow" 
                    text="🚪 Exit" 
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 12 30; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>
</BorderPane>