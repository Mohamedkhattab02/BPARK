<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="650" prefWidth="900" 
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 15; 
           -fx-border-radius: 15;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.RegisterSubscriberController">

    <effect>
        <DropShadow color="#00000080" radius="20.0" spread="0.1" offsetY="12" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 15 15 0 0; 
                     -fx-padding: 20;">
            <effect>
                <InnerShadow color="#ffffff20" radius="8.0" />
            </effect>
            
            <!-- Registration Icon and Title -->
            <HBox alignment="CENTER" spacing="15">
                <!-- Registration Avatar Circle -->
                <StackPane>
                    <Circle radius="30" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="27" 
                           style="-fx-fill: linear-gradient(to bottom, #22c55e, #16a34a);" />
                    <Label text="📝" style="-fx-font-size: 26px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="6.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Register New Subscriber" 
                           style="-fx-font-size: 28px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="28.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="4.0" />
                        </effect>
                    </Label>
                    <Label text="Create a new subscriber account" 
                           style="-fx-font-size: 12px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Main Content - Registration Form -->
    <center>
        <VBox alignment="CENTER" style="-fx-padding: 25; -fx-spacing: 20;">
            
            <!-- Registration Form Card -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 12; 
                         -fx-padding: 30; 
                         -fx-spacing: 20;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 12;
                         -fx-pref-width: 800;
                         -fx-max-width: 800;">
                <effect>
                    <DropShadow color="#00000020" radius="12.0" spread="0.05" />
                </effect>
                
                <!-- Card Header -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="✍️" style="-fx-font-size: 18px;" />
                    <Label text="Registration Information" 
                           style="-fx-font-size: 18px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="18.0" />
                        </font>
                    </Label>
                </HBox>
                
                <!-- Registration Form - Two Columns -->
                <HBox spacing="40" alignment="TOP_CENTER">
                    
                    <!-- Left Column -->
                    <VBox spacing="15" style="-fx-min-width: 350;">
                        
                        <!-- First Name -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="👤" style="-fx-font-size: 14px;" />
                                <Label text="First Name:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <TextField fx:id="txtFirstName" 
                                       style="-fx-text-fill: #1f2937; 
                                              -fx-font-size: 13px; 
                                              -fx-padding: 10 12; 
                                              -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                              -fx-background-radius: 6; 
                                              -fx-border-color: #cbd5e1;
                                              -fx-border-width: 1px;
                                              -fx-border-radius: 6;
                                              -fx-prompt-text-fill: #9ca3af;" 
                                       promptText="Enter first name" />
                        </VBox>

                        <!-- Last Name -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="👤" style="-fx-font-size: 14px;" />
                                <Label text="Last Name:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <TextField fx:id="txtLastName" 
                                       style="-fx-text-fill: #1f2937; 
                                              -fx-font-size: 13px; 
                                              -fx-padding: 10 12; 
                                              -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                              -fx-background-radius: 6; 
                                              -fx-border-color: #cbd5e1;
                                              -fx-border-width: 1px;
                                              -fx-border-radius: 6;
                                              -fx-prompt-text-fill: #9ca3af;" 
                                       promptText="Enter last name" />
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="📧" style="-fx-font-size: 14px;" />
                                <Label text="Email:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <TextField fx:id="txtEmail" 
                                       style="-fx-text-fill: #1f2937; 
                                              -fx-font-size: 13px; 
                                              -fx-padding: 10 12; 
                                              -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                              -fx-background-radius: 6; 
                                              -fx-border-color: #cbd5e1;
                                              -fx-border-width: 1px;
                                              -fx-border-radius: 6;
                                              -fx-prompt-text-fill: #9ca3af;" 
                                       promptText="Enter email address" />
                        </VBox>
                    </VBox>
                    
                    <!-- Right Column -->
                    <VBox spacing="15" style="-fx-min-width: 350;">
                        
                        <!-- Phone Number -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="📱" style="-fx-font-size: 14px;" />
                                <Label text="Phone Number:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <TextField fx:id="txtPhone" 
                                       style="-fx-text-fill: #1f2937; 
                                              -fx-font-size: 13px; 
                                              -fx-padding: 10 12; 
                                              -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                              -fx-background-radius: 6; 
                                              -fx-border-color: #cbd5e1;
                                              -fx-border-width: 1px;
                                              -fx-border-radius: 6;
                                              -fx-prompt-text-fill: #9ca3af;" 
                                       promptText="Enter phone number" />
                        </VBox>

                        <!-- Username -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="🆔" style="-fx-font-size: 14px;" />
                                <Label text="Username:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <TextField fx:id="txtUsername" 
                                       style="-fx-text-fill: #1f2937; 
                                              -fx-font-size: 13px; 
                                              -fx-padding: 10 12; 
                                              -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                              -fx-background-radius: 6; 
                                              -fx-border-color: #cbd5e1;
                                              -fx-border-width: 1px;
                                              -fx-border-radius: 6;
                                              -fx-prompt-text-fill: #9ca3af;" 
                                       promptText="Choose a username" />
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <Label text="🔒" style="-fx-font-size: 14px;" />
                                <Label text="Password:" 
                                       style="-fx-text-fill: #374151; 
                                              -fx-font-weight: bold; 
                                              -fx-font-size: 13px;" />
                            </HBox>
                            <PasswordField fx:id="txtPassword" 
                                           style="-fx-text-fill: #1f2937; 
                                                  -fx-font-size: 13px; 
                                                  -fx-padding: 10 12; 
                                                  -fx-background-color: linear-gradient(to bottom, #f8fafc, #f1f5f9); 
                                                  -fx-background-radius: 6; 
                                                  -fx-border-color: #cbd5e1;
                                                  -fx-border-width: 1px;
                                                  -fx-border-radius: 6;
                                                  -fx-prompt-text-fill: #9ca3af;" 
                                           promptText="Enter password" />
                        </VBox>
                    </VBox>
                </HBox>
                
                <!-- Status Message -->
                <Label fx:id="lblStatus" 
                       style="-fx-text-fill: #dc2626; 
                              -fx-font-size: 13px; 
                              -fx-font-weight: bold;
                              -fx-padding: 8;
                              -fx-alignment: center;" 
                       wrapText="true" />
            </VBox>
        </VBox>
    </center>

    <!-- Footer with Action Buttons -->
    <bottom>
        <HBox alignment="CENTER" spacing="15" 
              style="-fx-padding: 20; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 15 15;">
            
            <!-- Register Button -->
            <Button onAction="#handleRegister" 
                    text="✓ Register" 
                    style="-fx-background-color: linear-gradient(to bottom, #22c55e, #16a34a); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 15px; 
                           -fx-padding: 10 30; 
                           -fx-background-radius: 20; 
                           -fx-border-color: #15803d;
                           -fx-border-width: 1px;
                           -fx-border-radius: 20;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                </effect>
            </Button>
            
            <!-- Back Button -->
            <Button onAction="#handleBack" 
                    text="← Back" 
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 14px; 
                           -fx-padding: 10 25; 
                           -fx-background-radius: 20; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 20;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="6.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>
</BorderPane>