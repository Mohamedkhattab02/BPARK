<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0"
    style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298); 
           -fx-border-color: linear-gradient(to bottom, #3b82f6, #1d4ed8); 
           -fx-border-width: 2px; 
           -fx-background-radius: 20; 
           -fx-border-radius: 20;" 
    xmlns="http://javafx.com/javafx/23.0.1" 
    xmlns:fx="http://javafx.com/fxml/1" 
    fx:controller="clientGui.SubscriberReportController">

    <effect>
        <DropShadow color="#00000080" radius="25.0" spread="0.1" offsetY="15" />
    </effect>

    <!-- Header Section -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 20 20 0 0; 
                     -fx-padding: 25;">
            <effect>
                <InnerShadow color="#ffffff20" radius="10.0" />
            </effect>
            
            <!-- Icon and Title -->
            <HBox alignment="CENTER" spacing="20">
                <!-- Chart Icon Circle -->
                <StackPane>
                    <Circle radius="35" 
                           style="-fx-fill: linear-gradient(to bottom, #ffffff, #e2e8f0);" />
                    <Circle radius="32" 
                           style="-fx-fill: linear-gradient(to bottom, #22c55e, #16a34a);" />
                    <Label text="📈" style="-fx-font-size: 28px;" />
                    <effect>
                        <DropShadow color="#00000040" radius="8.0" />
                    </effect>
                </StackPane>
                
                <!-- Title -->
                <VBox alignment="CENTER_LEFT">
                    <Label text="Monthly Subscriber Report" 
                           style="-fx-font-size: 36px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: white;">
                        <font>
                            <Font name="Segoe UI Bold" size="36.0" />
                        </font>
                        <effect>
                            <DropShadow color="#00000060" radius="5.0" />
                        </effect>
                    </Label>
                    <Label text="Insights into monthly parking activity per subscriber" 
                           style="-fx-font-size: 14px; 
                                  -fx-text-fill: #e2e8f0; 
                                  -fx-font-style: italic;">
                        <effect>
                            <DropShadow color="#00000040" radius="2.0" />
                        </effect>
                    </Label>
                </VBox>
            </HBox>
            
            <!-- Decorative separator -->
            <Separator style="-fx-background-color: #ffffff40;" />
        </VBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" style="-fx-padding: 40;">
            <!-- Chart Card -->
            <VBox style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f8fafc); 
                         -fx-background-radius: 15; 
                         -fx-padding: 35; 
                         -fx-spacing: 25;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1px;
                         -fx-border-radius: 15;
                         -fx-max-width: 900;">
                <effect>
                    <DropShadow color="#00000020" radius="15.0" spread="0.05" />
                </effect>
                
                <!-- Card Header -->
                <HBox alignment="CENTER" spacing="10">
                    <Label text="👥" style="-fx-font-size: 24px;" />
                    <Label text="Subscriber Activity Analysis" 
                           style="-fx-font-size: 22px; 
                                  -fx-font-weight: bold; 
                                  -fx-text-fill: #1e40af;">
                        <font>
                            <Font name="Segoe UI Bold" size="22.0" />
                        </font>
                    </Label>
                </HBox>
                
                <Separator style="-fx-background-color: #e2e8f0;" />
                
                <!-- Time Comparison Boxes -->
                <HBox alignment="CENTER" spacing="50">
                    <VBox alignment="CENTER" 
                          style="-fx-background-color: linear-gradient(to bottom, #fed7aa, #fdba74);
                                 -fx-padding: 25;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #ea580c;
                                 -fx-border-width: 2px;
                                 -fx-border-radius: 12;
                                 -fx-min-width: 200;">
                        <effect>
                            <DropShadow color="#ea580c40" radius="10.0" spread="0.1" />
                        </effect>
                        <Label text="🕐" style="-fx-font-size: 24px;" />
                        <Label text="Allocated Time" 
                               style="-fx-font-size: 18px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #9a3412;" />
                        <Label text="Pre-assigned duration" 
                               style="-fx-font-size: 13px; 
                                      -fx-text-fill: #c2410c;" />
                    </VBox>
                    
                    <VBox alignment="CENTER" 
                          style="-fx-background-color: linear-gradient(to bottom, #fef3c7, #fde68a);
                                 -fx-padding: 25;
                                 -fx-background-radius: 12;
                                 -fx-border-color: #d97706;
                                 -fx-border-width: 2px;
                                 -fx-border-radius: 12;
                                 -fx-min-width: 200;">
                        <effect>
                            <DropShadow color="#d9770640" radius="10.0" spread="0.1" />
                        </effect>
                        <Label text="⏱️" style="-fx-font-size: 24px;" />
                        <Label text="Actual Time" 
                               style="-fx-font-size: 18px; 
                                      -fx-font-weight: bold; 
                                      -fx-text-fill: #92400e;" />
                        <Label text="Real usage duration" 
                               style="-fx-font-size: 13px; 
                                      -fx-text-fill: #b45309;" />
                    </VBox>
                </HBox>
                
                <!-- Chart Container -->
                <VBox style="-fx-background-color: #f8fafc;
                             -fx-padding: 20;
                             -fx-background-radius: 10;
                             -fx-border-color: #e2e8f0;
                             -fx-border-width: 1px;
                             -fx-border-radius: 10;">
                    <BarChart fx:id="subscriberChart" 
                              prefHeight="400.0" 
                              prefWidth="800.0" 
                              style="-fx-background-color: transparent;
                                     -fx-alternative-row-fill-visible: false;
                                     -fx-legend-side: RIGHT;">
                        <xAxis>
                            <CategoryAxis fx:id="statusAxis" label="Subscriber Name" 
                                         style="-fx-tick-label-fill: #374151;
                                                -fx-font-weight: bold;
                                                -fx-tick-label-rotation: -45;" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis label="Time (minutes)" 
                                       style="-fx-tick-label-fill: #374151;
                                              -fx-font-weight: bold;" />
                        </yAxis>
                    </BarChart>
                </VBox>
            </VBox>
        </VBox>
    </center>

    <!-- Footer with Actions -->
    <bottom>
        <HBox alignment="CENTER" spacing="20" 
              style="-fx-padding: 25; 
                     -fx-background-color: linear-gradient(to right, #667eea, #764ba2); 
                     -fx-background-radius: 0 0 20 20;">
            
            <Button text="← Back" 
                    onAction="#handleBack"
                    style="-fx-background-color: linear-gradient(to bottom, #ef4444, #dc2626); 
                           -fx-text-fill: white; 
                           -fx-font-weight: bold; 
                           -fx-font-size: 15px; 
                           -fx-padding: 12 35; 
                           -fx-background-radius: 25; 
                           -fx-border-color: #b91c1c;
                           -fx-border-width: 1px;
                           -fx-border-radius: 25;
                           -fx-cursor: hand;">
                <effect>
                    <DropShadow color="#00000040" radius="8.0" spread="0.1" />
                </effect>
            </Button>
        </HBox>
    </bottom>

</BorderPane>